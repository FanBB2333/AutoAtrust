# Copy to .env (which is gitignored) and fill in real values.
# auto_atrust.py reads these at startup.

# SSH endpoint hosting the aTrust container (user@host).
SSH_HOST=user@example.com

# SSH server port on the remote.
SSH_PORT=22

# VNC port — both the local forward and the remote listener (TigerVNC :1 → 5901).
VNC_PORT=5901

# VNC password (decrypted from /root/.vnc/passwd on the remote).
VNC_PASSWORD=changeme
